# Telar Knowledge Admin — experiments-telar
# Copy to .env on the experiments-telar instance and fill in real values.
# DO NOT commit the real .env file.

# Image tag to deploy (matches the GHCR tag pushed by CI, e.g. "develop" or a sha-XXXXXXX)
IMAGE_TAG=develop

# ============================================================
# AGENTS DATABASE — points to telar-stage's Postgres (pgvector)
# over its public IP. Requires the telar-stage Lightsail Security
# Group to allow inbound TCP 5432 from experiments-telar's IP.
# ============================================================
AGENTS_DB_URL=postgresql://postgres:<password>@52.7.98.126:5432/getinmotion

# ============================================================
# OPENAI CONFIGURATION (same as apps/agents/.env on stage)
# ============================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ============================================================
# RAG / CHUNKING CONFIGURATION
# ============================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RAG_TOP_K=5

# ============================================================
# ADMIN LOGIN
# Generate the hash with:
#   python3 -c "import hashlib; print(hashlib.sha256(b'your_password').hexdigest())"
# ============================================================
ADMIN_RAG_USERNAME=admin
ADMIN_RAG_PASSWORD_HASH=

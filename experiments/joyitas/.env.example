# ========================================
# Joyitas - Environment Variables Template
# ========================================

# ----------------------------------------
# Docker Images
# ----------------------------------------
API_IMAGE_TAG=latest
MARKETPLACE_IMAGE_TAG=latest

# ----------------------------------------
# API - Database Configuration
# ----------------------------------------
HOST_DB=your-db-host.com
PORT_DB=5432
USER_DB=postgres
PASS_DB=your_database_password
NAME_DB=joyitas
PASSWORD_SECRET=your-jwt-secret-change-this

# ----------------------------------------
# API - SMTP Email Configuration
# ----------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Email Sender
MAIL_FROM_NAME=Telar.co
MAIL_FROM_EMAIL=noreply@telar.store

# ----------------------------------------
# API - Frontend URLs
# ----------------------------------------
FRONTEND_URL=https://telar.store
LOGO_URL=https://telar.store/logo-horizontal.svg

# ----------------------------------------
# API - AI (OpenAI)
# ----------------------------------------
OPENAI_API_KEY=sk-proj-your-openai-api-key

# ----------------------------------------
# API - Google OAuth
# ----------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.telar.store/telar/server/auth/google/callback

# ----------------------------------------
# API - Supabase Migration DB
# ----------------------------------------
SUPABASE_DB_HOST=aws-0-us-east-2.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres.your-project-id
SUPABASE_DB_PASSWORD=your-supabase-db-password
SUPABASE_DB_NAME=postgres

# ----------------------------------------
# API - CDN
# ----------------------------------------
CDN_BASE_URL=https://your-bucket.s3.us-east-1.amazonaws.com

# ----------------------------------------
# API - Servientrega Shipping
# ----------------------------------------
SERVIENTREGA_LOGIN=your-servientrega-login
SERVIENTREGA_PASSWORD=your-servientrega-password
SERVIENTREGA_COD_FACTURACION=SER408
SERVIENTREGA_AUTH_URL=http://web.servientrega.com:8058/CotizadorCorporativo/api/autenticacion/login
SERVIENTREGA_QUOTE_URL=http://web.servientrega.com:8058/CotizadorCorporativo/api/cotizacion/cotizar
SERVIENTREGA_SOAP_URL=https://developer.servientrega.com/WsSisclinetGeneraGuias/GeneracionGuias.asmx
SERVIENTREGA_SOAP_ACTION_CARGUE=http://tempuri.org/CargueMasivoExterno
SERVIENTREGA_SOAP_ACTION_STICKER=http://tempuri.org/GenerarGuiaSticker

# ----------------------------------------
# API - Cobre Payment Gateway
# ----------------------------------------
COBRE_API_KEY=cli_your_cobre_api_key
COBRE_API_SECRET=your_cobre_api_secret
COBRE_BALANCE_ID=acc_your_balance_id
COBRE_URL=https://api.cobre.co

# ----------------------------------------
# API - AWS S3
# ----------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET_NAME=telar-bucket
AWS_REGION=us-east-1
AWS_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
AWS_S3_ACL=public-read
MAX_FILE_SIZE=5242880

# ----------------------------------------
# API - CMS & Agent
# ----------------------------------------
CMS_KEY=your-cms-key
AGENT_URL=https://stage-agents.telar.co/api

# ----------------------------------------
# Marketplace-Web - Backend & API
# ----------------------------------------
VITE_BACKEND_URL=https://api.telar.store/telar/server
VITE_API_PAYMENT_URL=https://api.telar.store

# ----------------------------------------
# Marketplace-Web - Supabase
# ----------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# ----------------------------------------
# Marketplace-Web - Semantic Search
# ----------------------------------------
VITE_SEMANTIC_SEARCH_API_URL=https://stage-agents.telar.co
VITE_SEMANTIC_SEARCH_API_KEY=your-semantic-search-api-key

# ========================================
# Joyitas - Environment Variables Template
# ========================================

# ----------------------------------------
# Docker Images
# ----------------------------------------
API_IMAGE_TAG=latest
MARKETPLACE_IMAGE_TAG=latest

# ----------------------------------------
# Database Configuration
# ----------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/database
DB_HOST=your-db-host.com
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_database_name

# ----------------------------------------
# API Configuration
# ----------------------------------------
API_URL=https://api.telar.store
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=7d

# ----------------------------------------
# Supabase (if using)
# ----------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ----------------------------------------
# Payment Gateways
# ----------------------------------------

# Cobre
COBRE_API_KEY=your-cobre-api-key
COBRE_BASE_URL=https://api.cobre.co
COBRE_BALANCE_ID=your-cobre-balance-id

# Wompi
WOMPI_BASE_URL=https://production.wompi.co
WOMPI_PUBLIC_KEY=pub_prod_your_wompi_public_key
WOMPI_PRIVATE_KEY=prv_prod_your_wompi_private_key

# ----------------------------------------
# Frontend (Marketplace-Web)
# ----------------------------------------
VITE_API_URL=https://api.telar.store
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_WOMPI_PUBLIC_KEY=pub_prod_your_wompi_public_key

# ----------------------------------------
# Optional Services
# ----------------------------------------
PAYMENT_SERVICE_URL=http://payment-svc:8080

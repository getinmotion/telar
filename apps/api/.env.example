# ========================================
# GetInMotion Server - Environment Variables
# ========================================

# ========================================
# DATABASE CONFIGURATION
# ========================================
HOST_DB=localhost
PORT_DB=5432
USER_DB=postgres
PASS_DB=tu_password_seguro_aqui
NAME_DB=getinmotion

# ========================================
# JWT CONFIGURATION
# ========================================
PASSWORD_SECRET=tu_jwt_secret_muy_seguro_aqui_minimo_32_caracteres

# ========================================
# OPENAI API
# ========================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ========================================
# APPLICATION
# ========================================
PORT=3040
NODE_ENV=development
ENVIRONMENT_PROJECT=dev

# ========================================
# DOCKER DEPLOYMENT (Producción)
# ========================================
# Para Docker, cambia HOST_DB a "postgres" (nombre del servicio)
# HOST_DB=postgres
# ENVIRONMENT_PROJECT=production
# NODE_ENV=production

# ========================================
# CDN / IMAGE STORAGE
# ========================================
# AWS S3 bucket URL for image storage
# Images are stored with relative paths in database (e.g., "/images/brand-assets/uuid/file.jpg")
# and transformed to full URLs at runtime using this base URL
CDN_BASE_URL=https://telar-stg-bucket.s3.us-east-1.amazonaws.com

# For production, use:
# CDN_BASE_URL=https://telar-prod-bucket.s3.us-east-1.amazonaws.com
# Or CloudFront CDN domain:
# CDN_BASE_URL=https://cdn.telar.com

# ========================================
# AWS S3 / LIGHTSAIL OBJECT STORAGE
# ========================================
# IMPORTANTE: NO COMPARTIR estas credenciales - mantener en .gitignore
# Obtener desde AWS Console → IAM → Users → Security credentials → Create access key

# Credenciales IAM (obligatorias)
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# Configuración del bucket (obligatorias)
AWS_S3_BUCKET_NAME=telar-stg-bucket
AWS_REGION=us-east-1

# Endpoint de S3/Lightsail (obligatorio)
# Para Lightsail: https://s3.{region}.amazonaws.com
# Para S3 estándar: https://s3.{region}.amazonaws.com
AWS_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com

# Permisos de archivos subidos (opcional)
# Opciones: 'public-read', 'private', 'authenticated-read'
AWS_S3_ACL=public-read

# Tamaño máximo de archivo (opcional - en bytes)
# 5MB = 5242880, 10MB = 10485760
MAX_FILE_SIZE=5242880

# Para producción:
# AWS_S3_BUCKET_NAME=telar-prod-bucket
# AWS_REGION=us-east-1
# AWS_S3_ACL=private

# ========================================
# SERVIENTREGA
# ========================================
SERVIENTREGA_LOGIN='su_usuario_de_servientrega'
SERVIENTREGA_PASSWORD='su_contraseña_de_servientrega'
SERVIENTREGA_COD_FACTURACION='su_codigo_de_facturacion_de_servientrega'

# ========================================
# COBRE PAYMENT API
# ========================================
# Cobre API credentials for payment processing
COBRE_API_KEY=your_cobre_api_key_here
COBRE_API_SECRET=your_cobre_api_secret_here
COBRE_URL=https://api.cobre.com

# ========================================
# STORYBLOK CMS
# ========================================
# Storyblok API access token for content management
CMS_KEY=your_storyblok_access_token_here

# CMS — MongoDB (local docker)
MONGO_URI=mongodb://localhost:27017/telar_cms
MONGO_PORT=27017

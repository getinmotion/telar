# ========================================
# CONEXIÓN A PRODUCCIÓN (ORIGEN)
# ========================================
# AWS Lightsail PostgreSQL
PROD_HOST_DB=ls-xxxx.xxxx.us-east-1.rds.amazonaws.com
PROD_PORT_DB=5432
PROD_USER_DB=dbadmin
PROD_PASS_DB=your_production_password_here
PROD_NAME_DB=getinmotion

# ========================================
# CONEXIÓN A LOCAL (DESTINO)
# ========================================
LOCAL_HOST_DB=localhost
LOCAL_PORT_DB=5432
LOCAL_USER_DB=postgres
LOCAL_PASS_DB=postgres
LOCAL_NAME_DB=getinmotion

# ========================================
# CONFIGURACIÓN DE MIGRACIÓN
# ========================================
# Continuar si una migración falla
CONTINUE_ON_ERROR=false

# Logging level (info, debug, error)
LOG_LEVEL=info

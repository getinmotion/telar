<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Tu acceso a TELAR</title>
  </head>
  <body
    style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f5f5f5;"
  >
    <table role='presentation' style='width: 100%; border-collapse: collapse;'>
      <tr>
        <td align='center' style='padding: 40px 20px;'>
          <table
            role='presentation'
            style='max-width: 600px; width: 100%; background-color: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);'
          >
            <!-- Header -->
            <tr>
              <td
                style='background: linear-gradient(135deg, #f48c5f 0%, #e67e22 100%); padding: 32px; text-align: center;'
              >
                {{#if logoUrl}}
                  <img
                    src='{{logoUrl}}'
                    alt='TELAR'
                    style='height: 50px; margin-bottom: 15px;'
                  />
                {{/if}}
                <h1
                  style='margin: 0; color: #ffffff; font-size: 28px; font-weight: 700;'
                >🎉 ¡Bienvenido, {{name}}!</h1>
              </td>
            </tr>

            <!-- Content -->
            <tr>
              <td style='padding: 32px;'>
                <p
                  style='margin: 0 0 24px; color: #666; font-size: 16px; line-height: 1.5;'
                >
                  Tu cuenta en
                  <strong>TELAR</strong>
                  ha sido verificada. Estas son tus credenciales de acceso:
                </p>

                <div
                  style='background-color: #f8fafc; border-radius: 10px; border: 1px solid #e0e0e0; padding: 20px; margin-bottom: 24px;'
                >
                  <p
                    style='margin: 8px 0; color: #142239; font-size: 16px;'
                  >Correo:
                    <span
                      style="font-weight: 700; font-family: 'Courier New', Courier, monospace;"
                    >{{email}}</span></p>
                  <p
                    style='margin: 8px 0; color: #142239; font-size: 16px;'
                  >Contraseña:
                    <span
                      style="font-weight: 700; font-family: 'Courier New', Courier, monospace;"
                    >{{password}}</span></p>
                </div>

                <div style='text-align: center; margin-bottom: 24px;'>
                  <a
                    href='{{loginUrl}}'
                    style='display: inline-block; padding: 16px 40px; background-color: #142239; color: #ffffff; text-decoration: none; border-radius: 10px; font-weight: 600; font-size: 16px;'
                  >
                    Iniciar sesión
                  </a>
                </div>

                <p
                  style='margin: 0; color: #999; font-size: 13px; font-style: italic;'
                >
                  Por seguridad, te recomendamos cambiar esta contraseña después
                  de iniciar sesión.
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                style='padding: 24px 32px; background-color: #142239; text-align: center;'
              >
                <p style='margin: 0 0 8px; color: #ffffff; font-size: 14px;'>Con
                  cariño desde Bogotá, Colombia 🇨🇴</p>
                <p
                  style='margin: 0; color: rgba(255,255,255,0.6); font-size: 12px;'
                >Conectando artesanos con el mundo</p>
                <div
                  style='margin-top: 16px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.1);'
                >
                  <p
                    style='margin: 0; color: rgba(255,255,255,0.6); font-size: 12px;'
                  >TELAR © {{year}}</p>
                </div>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
# ── apps/marketplace-web — Vite env ──────────────────────────────
# Copia este archivo a `.env` (gitignored) y rellena los valores.

# Backend NestJS (telar/server)
VITE_BACKEND_URL=http://localhost:1010/telar/server

# Supabase (uso legacy: ProductReviews, NotifyWhenAvailable, Wishlist, etc.)
# Si NO los configuras, esos features tirarán warning pero la app booteará igual.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Payment microservice
VITE_API_PAYMENT_URL=http://localhost:1011

# Storyblok (preview token — opcional, solo si activas el editor)
VITE_STORYBLOK_PREVIEW_TOKEN=

# Agreement ID (obligatorio — filtra productos del marketplace)
VITE_AGREEMENT_ID=

# Semantic search (opcional)
VITE_SEMANTIC_SEARCH_API_URL=
VITE_SEMANTIC_SEARCH_API_KEY=

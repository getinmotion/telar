# GetInMotion Agents Service - Environment Variables
# Configuration for the multi-agent system

# ============================================================
# OPENAI CONFIGURATION
# ============================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ============================================================
# AGENTS DATABASE (Lightsail PostgreSQL — agents schema)
# Stores: conversations, memory, artisan profiles, RAG embeddings
#
# Local dev (SSH tunnel):
#   ssh -i ~/Downloads/LightsailDefaultKey-us-east-1.pem \
#       -L 5433:localhost:5432 ubuntu@52.7.98.126 -N -f
#   AGENTS_DB_URL=postgresql://postgres:<password>@localhost:5433/getinmotion
#
# Run migration first:
#   psql "$AGENTS_DB_URL" -f scripts/migrate_agents_db.sql
# ============================================================
AGENTS_DB_URL=postgresql://postgres:password@localhost:5433/getinmotion

# ============================================================
# CATALOG DATABASE (Lightsail PostgreSQL — shop.* and taxonomy.* tables)
# Required for semantic search and batch embedding indexing.
#
# Local dev:
#   CATALOG_DB_URL=postgresql://postgres:password@localhost:5432/getinmotion
# ============================================================
CATALOG_DB_URL=postgresql://postgres:password@localhost:5432/getinmotion

# ============================================================
# API SECURITY
# ============================================================
API_SECRET_KEY=your_secret_key_here_generate_with_openssl

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info

# ============================================================
# IMAGE UPLOADS (local filesystem — served as static files)
# UPLOAD_DIR: absolute or relative path where images are saved
# BASE_URL:   public base URL of this service (used to build image URLs)
# ============================================================
UPLOAD_DIR=./uploads/product-photos
BASE_URL=http://localhost:8000

# ============================================================
# LANGSMITH CONFIGURATION (Optional — for tracing/monitoring)
# ============================================================
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=artisan-agents
LANGSMITH_TRACING=true

# ============================================================
# TAVILY WEB SEARCH (Required for Pricing Agent)
# ============================================================
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================
# AGENT CONFIGURATION
# ============================================================
MAX_RETRIES=3
REQUEST_TIMEOUT=60
RAG_TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_BATCH_SIZE=100
EMBEDDING_CACHE_SIZE=1000

# ============================================================
# MEMORY CONFIGURATION (Hierarchical Memory System)
# ============================================================
MEMORY_RETRIEVAL_LIMIT=10
MEMORY_IMPORTANCE_THRESHOLD=0.5
PROFILE_UPDATE_INTERVAL=5
CONVERSATION_SUMMARY_INTERVAL=10

# ============================================================
# WHATSAPP BUSINESS API
# ============================================================
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
